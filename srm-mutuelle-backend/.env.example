# =============================================================================
# Fichier d'exemple pour le backend SRM-MS
# Copier vers .env :  copy .env.example .env   (Windows)
#                     cp .env.example .env    (Linux / macOS)
# Ne jamais commiter .env (secrets) — il est listé dans .gitignore
# =============================================================================

# Port sur lequel l'API Spring Boot écoute (défaut Spring si absent : 8080)
SERVER_PORT=8080

# URL JDBC PostgreSQL. Format : jdbc:postgresql://HÔTE:PORT/NOM_BASE
# - Base sans tiret : jdbc:postgresql://localhost:5432/srm_mutuelle
# - Base avec tiret : jdbc:postgresql://localhost:5432/"SRM-MS" → en JDBC utiliser le nom tel que créé, ex. :
#   jdbc:postgresql://localhost:5432/SRM-MS  (selon votre config PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/srm_mutuelle

# Utilisateur PostgreSQL (souvent postgres en local, ou un utilisateur dédié)
DB_USERNAME=postgres

# Mot de passe de cet utilisateur (à personnaliser en production)
DB_PASSWORD=postgres

# Comportement Hibernate sur le schéma : update = crée/met à jour les tables sans tout effacer
# Autres valeurs courantes : none, validate, create, create-drop (déconseillé en prod)
JPA_DDL_AUTO=update

# Afficher les requêtes SQL dans la console (true utile en dev ; false en prod)
JPA_SHOW_SQL=true

# JWT — secret d’au moins 32 caractères (obligatoire en production)
JWT_SECRET=srm-ms-dev-jwt-secret-key-change-me-32b!!

# Durée de vie du token d’accès (ms)
JWT_EXPIRATION_MS=86400000

# Origines CORS autorisées pour le front (Vite), séparées par des virgules
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Côté SPA (Vite), l’URL de cette API se configure dans srm-mutuelle-web/.env via VITE_API_BASE_URL (voir le .env.example du module web).

