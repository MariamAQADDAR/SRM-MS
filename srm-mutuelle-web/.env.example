# URL du backend Spring Boot (sans slash final). Même port que SERVER_PORT dans srm-mutuelle-backend/.env
# (8082 en local si 8081 est utilisé par Expo). En dev, vide = proxy Vite (voir vite.config.js).
VITE_API_BASE_URL=http://localhost:8082
# Si VITE_API_BASE_URL est vide, décommenter pour forcer la cible du proxy /api :
# VITE_DEV_PROXY_TARGET=http://localhost:8082
